NODE_ENV=production
PORT=5173
HOST=0.0.0.0
PUBLIC_BASE_URL=https://hiberota.com
APP_URL=https://hiberota.com
CALL_CACHE_TTL_MS=3600000
SOURCE_TIMEOUT_MS=12000
SOURCE_USER_AGENT=Hiberota/1.0 (+https://hiberota.com; contact: info@hiberota.com)
AUTOMATION_STATE_PATH=/app/.hiberota/automation-state.json
DATABASE_PATH=/app/.hiberota/database.sqlite
DATABASE_BACKUP_DIR=/app/.hiberota/backups
CRAWLER_CONCURRENCY=2
CRAWLER_JOB_TIMEOUT_MS=15000
ENABLE_DEEP_SCRAPING=true
LINK_VERIFY_LIMIT=25
LINK_VERIFY_TIMEOUT_MS=5000
LINK_HEALTH_WORKER_DELAY_MS=1000
LINK_HEALTH_WORKER_LIMIT=25
LINK_HEALTH_MAX_AGE_MS=86400000
CONFIDENCE_AUTO_PUBLISH_MIN=75
CONFIDENCE_MANUAL_REVIEW_MIN=50
MAX_JSON_BODY=32kb
MAX_URL_LENGTH=2048
MAX_SSE_CLIENTS=100
CRAWL_FREQ_TUBITAK_MIN=180
CRAWL_FREQ_TUSEB_MIN=240
CRAWL_FREQ_EU_MIN=120
CRAWL_FREQ_INTL_MIN=180

# Generate on the VPS with:
# openssl rand -hex 32
ADMIN_API_TOKEN=replace-with-64-hex-random-token
SESSION_SECRET=replace-with-64-hex-random-session-secret
ADMIN_USERNAME=admin

# Generate with:
# npm run admin:hash -- "your-long-admin-password"
ADMIN_PASSWORD_HASH=scrypt$replace-with-salt$replace-with-derived-hash
ADMIN_SESSION_TTL_MS=28800000

RESEND_API_KEY=
RESEND_FROM_EMAIL=Hibe Rota <bildirim@hiberota.com>
RESEND_REPLY_TO=destek@hiberota.com
RESEND_WEBHOOK_SECRET=
CRON_SECRET=replace-with-64-hex-random-cron-secret
EMAIL_NOTIFICATION_ENABLED=true
EMAIL_NOTIFICATION_CONFIDENCE_MIN=80

# Only needed if the optional postgres profile is enabled.
POSTGRES_PASSWORD=replace-with-long-random-postgres-password
