NODE_ENV=production
PORT=5173
HOST=0.0.0.0
CALL_CACHE_TTL_MS=3600000
SOURCE_TIMEOUT_MS=12000
SOURCE_USER_AGENT=Hiberota/1.0 (+https://example.com; contact: admin@example.com)
AUTOMATION_STATE_PATH=.hiberota/automation-state.json
CRAWLER_CONCURRENCY=2
CRAWLER_JOB_TIMEOUT_MS=15000
ENABLE_DEEP_SCRAPING=true
LINK_VERIFY_LIMIT=25
LINK_VERIFY_TIMEOUT_MS=5000
LINK_HEALTH_WORKER_DELAY_MS=1000
LINK_HEALTH_WORKER_LIMIT=25
LINK_HEALTH_MAX_AGE_MS=86400000
CONFIDENCE_AUTO_PUBLISH_MIN=75
CONFIDENCE_MANUAL_REVIEW_MIN=50
ADMIN_API_TOKEN=change-me-with-a-long-random-secret
MAX_JSON_BODY=32kb
MAX_URL_LENGTH=2048
MAX_SSE_CLIENTS=100
CRAWL_FREQ_TUBITAK_MIN=180
CRAWL_FREQ_TUSEB_MIN=240
CRAWL_FREQ_EU_MIN=120
CRAWL_FREQ_INTL_MIN=180
